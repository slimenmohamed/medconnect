{
  "realm": "medconnect",
  "enabled": true,
  "loginTheme": "medconnect",
  "displayName": "MedConnect",
  "displayNameHtml": "<b>MedConnect</b>",
  "sslRequired": "none",
  "registrationAllowed": false,
  "rememberMe": true,
  "loginWithEmailAllowed": true,

  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "roles": {
    "realm": [
      { "name": "PATIENT", "description": "Patient utilisateur" },
      { "name": "DOCTOR",  "description": "Médecin du cabinet" },
      { "name": "ADMIN",   "description": "Administrateur de la plateforme" }
    ]
  },

  "clients": [
    {
      "clientId": "medconnect-gateway",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "medconnect-gateway-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    },
    {
      "clientId": "medconnect-frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost",
      "baseUrl": "http://localhost",
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:4200/*",
        "http://localhost:80/*"
      ],
      "webOrigins": [
        "http://localhost",
        "http://localhost:4200",
        "http://localhost:80",
        "+"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      }
    }
  ],

  "users": [
    {
      "username": "patient",
      "enabled": true,
      "email": "patient@medconnect.local",
      "emailVerified": true,
      "firstName": "Sara",
      "lastName": "Alaoui",
      "credentials": [
        { "type": "password", "value": "patient123", "temporary": false }
      ],
      "realmRoles": ["PATIENT"]
    },
    {
      "username": "doctor",
      "enabled": true,
      "email": "doctor@medconnect.local",
      "emailVerified": true,
      "firstName": "Yassine",
      "lastName": "Idrissi",
      "credentials": [
        { "type": "password", "value": "doctor123", "temporary": false }
      ],
      "realmRoles": ["DOCTOR"]
    },
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@medconnect.local",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "MedConnect",
      "credentials": [
        { "type": "password", "value": "admin123", "temporary": false }
      ],
      "realmRoles": ["ADMIN"]
    }
  ],

  "defaultDefaultClientScopes": [
    "web-origins", "role_list", "profile", "roles", "email"
  ],
  "defaultOptionalClientScopes": [
    "address", "phone", "offline_access", "microprofile-jwt"
  ]
}
